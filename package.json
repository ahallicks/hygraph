{
	"name": "front-end-uk",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev": "react-router dev",
		"format": "prettier \"*/**/*.{js,jsx,ts,tsx,json,md,css,scss}\" --write",
		"formatw": "prettier \"{,!(node_modules)/**/}*.js\"",
		"lint": "run-p lint:*",
		"lint:js": "eslint \"*/**/*.{js,jsx,ts,tsx}\" --fix",
		"lint:css": "stylelint \"./**/*.{css,scss}\" --fix",
		"lint:ts": "tsc -p tsconfig.json --noEmit && npm run typecheck",
		"typecheck": "react-router typegen && tsc",
		"prepare": "husky",
		"start": "react-router-serve ./build/server/index.js",
		"test": "vitest",
		"test:pre-commit": "vitest run --changed"
	},
	"dependencies": {
		"@graphcms/rich-text-react-renderer": "^0.6.2",
		"@headlessui/react": "^2.2.9",
		"@heroicons/react": "^2.2.0",
		"@hygraph/preview-sdk": "^1.0.7",
		"@react-router/fs-routes": "^7.13.2",
		"@react-router/node": "7.13.2",
		"@react-router/serve": "7.13.2",
		"clsx": "^2.1.1",
		"dotenv": "^17.3.1",
		"graphql": "^16.13.2",
		"graphql-request": "^7.4.0",
		"isbot": "^5.1.36",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "7.13.2",
		"react-syntax-highlighter": "^16.1.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
		"@eslint/compat": "^2.0.3",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@react-router/dev": "7.13.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/jest-axe": "^3.5.9",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@vitejs/devtools": "^0.1.11",
		"@vitejs/plugin-basic-ssl": "^2.3.0",
		"@vitejs/plugin-react": "^6.0.1",
		"autoprefixer": "^10.4.27",
		"eslint": "^10.1.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-deprecation": "^3.0.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jest-dom": "^5.5.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-storybook": "^10.3.3",
		"eslint-plugin-testing-library": "^7.16.2",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"lint-staged": "^16.4.0",
